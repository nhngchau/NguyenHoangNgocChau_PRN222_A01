@model IEnumerable<NguyenHoangNgocChauBusinessObjects.Models.NewsArticle>
<h2>News report</h2><form class="row g-2 mb-3"><div class="col"><input class="form-control" type="date" name="startDate" required/></div><div class="col"><input class="form-control" type="date" name="endDate" required/></div><div class="col"><button class="btn btn-primary">Filter</button></div></form><div asp-validation-summary="ModelOnly" class="text-danger"></div><table class="table"><tr><th>ID</th><th>Title</th><th>Headline</th><th>Category</th><th>Created</th><th>Created by</th><th>Status</th></tr>@foreach(var x in Model){<tr><td>@x.NewsArticleId</td><td>@x.NewsTitle</td><td>@x.Headline</td><td>@x.Category?.CategoryName</td><td>@x.CreatedDate</td><td>@x.CreatedBy?.AccountName</td><td>@x.NewsStatus</td></tr>}</table>

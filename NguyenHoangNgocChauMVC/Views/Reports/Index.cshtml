@model IEnumerable<NguyenHoangNgocChauBusinessObjects.Models.NewsArticle>
@{
    ViewData["Title"]="Reports";
    var items=Model ?? Enumerable.Empty<NguyenHoangNgocChauBusinessObjects.Models.NewsArticle>();
    var hasFilter=!string.IsNullOrEmpty(Context.Request.Query["startDate"])&&!string.IsNullOrEmpty(Context.Request.Query["endDate"]);
    var start=Context.Request.Query["startDate"].ToString();
    var end=Context.Request.Query["endDate"].ToString();
    var total=items.Count();
    var active=items.Count(x=>x.NewsStatus==true);
    var inactive=total-active;
    var categories=items.Where(x=>x.Category!=null).Select(x=>x.Category!.CategoryName).Distinct().Count();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0"><i class="bi bi-graph-up-arrow text-primary me-2"></i>News Statistics Report</h2>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4 animate-fade-in-down">
    <div class="card-body p-4">
        <form class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-medium small text-muted text-uppercase"><i class="bi bi-calendar-event me-1"></i>From date</label>
                <input class="form-control" type="date" name="startDate" value="@start" required/>
            </div>
            <div class="col-md-5">
                <label class="form-label fw-medium small text-muted text-uppercase"><i class="bi bi-calendar-check me-1"></i>To date</label>
                <input class="form-control" type="date" name="endDate" value="@end" required/>
            </div>
            <div class="col-md-2 d-grid">
                <button class="btn btn-primary rounded-pill shadow-sm"><i class="bi bi-funnel-fill me-1"></i>Filter</button>
            </div>
        </form>
        <div asp-validation-summary="ModelOnly" class="text-danger mt-3 mb-0"></div>
    </div>
</div>

@if(hasFilter){
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 animate-fade-in-down">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px"><i class="bi bi-collection fs-5"></i></div>
                <div><div class="fs-3 fw-bold lh-1">@total</div><div class="text-muted small">Total articles</div></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 animate-fade-in-down">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px"><i class="bi bi-check-circle fs-5"></i></div>
                <div><div class="fs-3 fw-bold lh-1">@active</div><div class="text-muted small">Active</div></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 animate-fade-in-down">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-secondary bg-opacity-10 text-secondary d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px"><i class="bi bi-slash-circle fs-5"></i></div>
                <div><div class="fs-3 fw-bold lh-1">@inactive</div><div class="text-muted small">Inactive</div></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 animate-fade-in-down">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-info bg-opacity-10 text-info d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px"><i class="bi bi-tags fs-5"></i></div>
                <div><div class="fs-3 fw-bold lh-1">@categories</div><div class="text-muted small">Categories</div></div>
            </div>
        </div>
    </div>
</div>
}

<div class="table-wrapper animate-fade-in-down">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:10%">ID</th>
                    <th style="width:35%">Article</th>
                    <th style="width:15%">Category</th>
                    <th style="width:15%">Created</th>
                    <th style="width:15%">Created by</th>
                    <th style="width:10%">Status</th>
                </tr>
            </thead>
            <tbody>
                @if(total==0){
                <tr>
                    <td colspan="6" class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                        @(hasFilter?"No news articles found in the selected period.":"Pick a date range above to generate the report.")
                    </td>
                </tr>
                }else{
                @foreach(var x in items){
                <tr>
                    <td class="text-muted font-monospace small">@x.NewsArticleId</td>
                    <td>
                        <h6 class="fw-bold mb-1 text-dark">@x.NewsTitle</h6>
                        <p class="text-muted small mb-0">@x.Headline</p>
                    </td>
                    <td><span class="badge bg-light text-dark border">@(x.Category?.CategoryName ?? "—")</span></td>
                    <td class="small text-muted"><i class="bi bi-calendar3 me-1"></i>@x.CreatedDate?.ToString("MMM dd, yyyy")</td>
                    <td class="small">@(x.CreatedBy?.AccountName ?? "—")</td>
                    <td>
                        <span class="badge rounded-pill bg-@(x.NewsStatus==true?"success":"secondary")">
                            <i class="bi bi-circle-fill small me-1"></i>@(x.NewsStatus==true?"Active":"Inactive")
                        </span>
                    </td>
                </tr>
                }
                }
            </tbody>
        </table>
    </div>
</div>

@model NguyenHoangNgocChauBusinessObjects.Models.SystemAccount
@{ ViewData["Title"] = "My Profile"; }

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <h2 class="fw-bold m-0"><i class="bi bi-person-vcard text-primary me-2"></i>My Profile</h2>
        </div>

        <div class="card shadow-lg border-0 animate-fade-in-down rounded-4 overflow-hidden">
            <div class="card-header bg-primary text-white p-4 text-center border-0">
                <i class="bi bi-person-circle display-1 opacity-75"></i>
                <h4 class="mt-2 mb-0 fw-bold">@Model?.AccountName</h4>
                <p class="mb-0 text-white-50 small">@(Model?.AccountRole == 1 ? "Staff Member" : "Lecturer")</p>
            </div>
            <div class="card-body p-4 p-md-5 bg-white">
                <form method="post">
                    <div class="form-floating mb-3">
                        <input id="AccountName" class="form-control bg-light" name="AccountName" value="@Model?.AccountName" placeholder="Full Name" required/>
                        <label for="AccountName"><i class="bi bi-person me-2 text-muted"></i>Full Name</label>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input id="AccountEmail" class="form-control bg-light" name="AccountEmail" type="email" value="@Model?.AccountEmail" placeholder="Email Address" required/>
                        <label for="AccountEmail"><i class="bi bi-envelope me-2 text-muted"></i>Email Address</label>
                    </div>

                    <div class="form-floating mb-4">
                        <!-- Using type="text" or "password" depending on preference, standard is password, but we can allow them to see it or edit it -->
                        <input id="AccountPassword" class="form-control bg-light" name="AccountPassword" type="password" value="@Model?.AccountPassword" placeholder="Password" required/>
                        <label for="AccountPassword"><i class="bi bi-shield-lock me-2 text-muted"></i>Password</label>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-controller="News" asp-action="Index" class="btn btn-light rounded-pill px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                            <i class="bi bi-save me-2"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

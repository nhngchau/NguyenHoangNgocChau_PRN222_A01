@{var role=Context.Session.GetString("Role");var name=Context.Session.GetString("Name");var roleName=role=="0"?"Admin":role=="1"?"Staff":role=="2"?"Lecturer":"Guest";}<!DOCTYPE html><html><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>@ViewData["Title"] | FU News</title><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"><link rel="stylesheet" href="~/css/site.css"/></head><body><nav class="navbar navbar-expand-lg navbar-dark app-nav mb-4"><div class="container"><a class="navbar-brand fw-bold" asp-controller="News" asp-action="Index"><i class="bi bi-newspaper me-2"></i>FU News</a><button class="navbar-toggler border-0 shadow-none" data-bs-toggle="collapse" data-bs-target="#nav"><span class="navbar-toggler-icon"></span></button><div class="collapse navbar-collapse" id="nav"><div class="navbar-nav me-auto fw-medium">@if(role==null){<a class="nav-link" asp-controller="News" asp-action="Index"><i class="bi bi-globe me-1"></i>Public News</a><a class="nav-link" asp-controller="Auth" asp-action="Login"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a>}else if(role=="0"){<a class="nav-link" asp-controller="Accounts" asp-action="Index"><i class="bi bi-people me-1"></i>Accounts</a><a class="nav-link" asp-controller="Reports" asp-action="Index"><i class="bi bi-graph-up me-1"></i>Reports</a>}else if(role=="1"){<a class="nav-link" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags me-1"></i>Categories</a><a class="nav-link" asp-controller="News" asp-action="Index"><i class="bi bi-journal-text me-1"></i>News</a><a class="nav-link" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-badge me-1"></i>Profile</a><a class="nav-link" asp-controller="News" asp-action="History"><i class="bi bi-clock-history me-1"></i>History</a>}else{<a class="nav-link" asp-controller="News" asp-action="Index"><i class="bi bi-journal-text me-1"></i>News</a>}</div>@if(role!=null){<div class="d-flex align-items-center"><span class="navbar-text text-white-50 me-3"><i class="bi bi-person-circle me-1"></i>@name <span class="badge bg-light text-dark ms-1">@roleName</span></span><a class="btn btn-sm btn-outline-light rounded-pill px-3" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-1"></i>Logout</a></div>}</div></div></nav><main class="container">@if(TempData["Success"]!=null){<div class="alert alert-success alert-dismissible fade show animate-fade-in-down"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]<button class="btn-close" data-bs-dismiss="alert"></button></div>}@if(TempData["Error"]!=null){<div class="alert alert-danger alert-dismissible fade show animate-fade-in-down"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]<button class="btn-close" data-bs-dismiss="alert"></button></div>}@RenderBody()</main><footer class="text-center text-muted mt-5 mb-3 small">&copy; 2026 FU News Management System.</footer><script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>@await RenderSectionAsync("Scripts",false)</body></html>

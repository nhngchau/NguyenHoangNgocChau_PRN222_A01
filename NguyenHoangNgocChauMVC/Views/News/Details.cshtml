@model NguyenHoangNgocChauBusinessObjects.Models.NewsArticle
@{ ViewData["Title"] = "News details"; var staff = Context.Session.GetString("Role") == "1"; var admin = Context.Session.GetString("Role") == "0"; }
<article class="card shadow-lg border-0 animate-fade-in-down rounded-4 overflow-hidden mb-5">
    <div class="card-body p-4 p-md-5">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
            <div>
                <h1 class="fw-bolder text-dark mb-2">@Model.NewsTitle</h1>
                <p class="lead text-muted fst-italic">@Model.Headline</p>
            </div>
            @if(staff || admin){
                <span class="badge rounded-pill bg-@(Model.NewsStatus == true ? "success" : "secondary") shadow-sm px-3 py-2 mt-2">
                    <i class="bi bi-circle-fill small me-1"></i>@(Model.NewsStatus == true ? "Active" : "Inactive")
                </span>
            }
        </div>

        <div class="row g-4 text-muted small bg-light p-3 rounded-4 mb-4">
            <div class="col-sm-6 col-md-3">
                <div class="fw-bold text-uppercase mb-1"><i class="bi bi-folder2-open me-1 text-primary"></i>Category</div>
                <div>@Model.Category?.CategoryName</div>
            </div>
            <div class="col-sm-6 col-md-3">
                <div class="fw-bold text-uppercase mb-1"><i class="bi bi-link-45deg me-1 text-primary"></i>Source</div>
                <div>@Model.NewsSource</div>
            </div>
            <div class="col-sm-6 col-md-3">
                <div class="fw-bold text-uppercase mb-1"><i class="bi bi-calendar-event me-1 text-primary"></i>Published</div>
                <div>@Model.CreatedDate?.ToString("MMM dd, yyyy")</div>
            </div>
            @if(Model.CreatedBy is not null){
            <div class="col-sm-6 col-md-3">
                <div class="fw-bold text-uppercase mb-1"><i class="bi bi-pen me-1 text-primary"></i>Author</div>
                <div>@Model.CreatedBy.AccountName</div>
            </div>
            }
        </div>

        <div class="news-content fs-5 text-dark lh-lg mb-5" style="white-space: pre-line;">
            @Model.NewsContent
        </div>

        @if(Model.NewsTags.Any()){
            <div class="mb-4">
                <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-tags me-2"></i>Tags</h6>
                <div class="d-flex flex-wrap gap-2">
                    @foreach(var newsTag in Model.NewsTags){
                        <span class="badge rounded-pill bg-white border text-primary shadow-sm px-3 py-2">
                            #@newsTag.Tag?.TagName
                        </span>
                    }
                </div>
            </div>
        }

        <hr class="my-4 text-muted" />

        <div class="d-flex justify-content-between align-items-center">
            <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Index">
                <i class="bi bi-arrow-left me-1"></i>@(staff ? "Back to Manage News" : "Back to News List")
            </a>
        </div>
    </div>
</article>

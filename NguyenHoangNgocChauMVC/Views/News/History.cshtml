@model IEnumerable<NguyenHoangNgocChauBusinessObjects.Models.NewsArticle>
@{ ViewData["Title"] = "My News History"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0"><i class="bi bi-clock-history text-primary me-2"></i>My News History</h2>
</div>

<div class="table-wrapper animate-fade-in-down">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 15%">ID</th>
                    <th style="width: 45%">Title</th>
                    <th style="width: 25%">Created Date</th>
                    <th style="width: 15%">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var x in Model){
                <tr>
                    <td class="text-muted font-monospace small">@x.NewsArticleId</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@x.NewsArticleId" class="text-decoration-none fw-bold text-dark hover-primary">
                            @x.NewsTitle
                        </a>
                    </td>
                    <td class="small text-muted"><i class="bi bi-calendar3 me-1"></i>@x.CreatedDate?.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>
                        <span class="badge rounded-pill bg-@(x.NewsStatus==true?"success":"secondary")">
                            <i class="bi bi-circle-fill small me-1"></i>@(x.NewsStatus==true?"Active":"Inactive")
                        </span>
                    </td>
                </tr>
                }
                @if(!Model.Any()){
                    <tr><td colspan="4" class="text-center py-4 text-muted fst-italic">You haven't created any news articles yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

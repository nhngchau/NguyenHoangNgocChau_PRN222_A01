@{ViewData["Title"]="Login";}<div class="row justify-content-center login-page"><div class="col-md-6 col-lg-4"><div class="card shadow-lg border-0 animate-fade-in-down"><div class="card-body p-4 p-md-5"><div class="text-center mb-4"><div class="mb-3"><i class="bi bi-person-circle display-4 text-primary"></i></div><h3 class="fw-bold text-dark">Welcome back</h3><p class="text-muted small">FU News Management System</p></div><form method="post"><div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 p-2 small"><i class="bi bi-exclamation-triangle-fill me-1"></i></div><div class="form-floating mb-3"><input class="form-control" name="email" id="floatingInput" type="email" placeholder="name@example.com" required autofocus/><label for="floatingInput">Email address</label></div><div class="form-floating mb-4"><input class="form-control" name="password" id="floatingPassword" type="password" placeholder="Password" required/><label for="floatingPassword">Password</label></div><button class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm"><i class="bi bi-box-arrow-in-right me-2"></i>Sign in</button></form><div class="text-center mt-4"><a asp-controller="News" asp-action="Index" class="text-decoration-none text-muted small hover-primary"><i class="bi bi-globe me-1"></i>Continue as Guest → Public News</a></div></div></div></div></div>

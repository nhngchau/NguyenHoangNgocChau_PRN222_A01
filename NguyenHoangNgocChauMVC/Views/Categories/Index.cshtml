@model IEnumerable<NguyenHoangNgocChauBusinessObjects.Models.Category>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0"><i class="bi bi-tags-fill text-primary me-2"></i>Category Management</h2>
    <button class="btn btn-primary shadow-sm rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#categoryModal" onclick="openCategory()">
        <i class="bi bi-plus-lg me-1"></i> Create category
    </button>
</div>
<form class="mb-4">
    <div class="input-group shadow-sm rounded-pill overflow-hidden">
        <span class="input-group-text bg-white border-0 ps-4"><i class="bi bi-search text-muted"></i></span>
        <input class="form-control border-0 py-2" name="q" value="@ViewBag.Query" placeholder="Search categories..." />
    </div>
</form>
<div class="table-wrapper animate-fade-in-down">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th class="text-end px-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var x in Model){
                <tr>
                    <td class="fw-medium text-dark">@x.CategoryName</td>
                    <td class="text-muted">@x.CategoryDescription</td>
                    <td>
                        <span class="badge rounded-pill bg-@(x.IsActive==true?"success":"secondary")">
                            <i class="bi bi-circle-fill small me-1"></i>@(x.IsActive==true?"Active":"Inactive")
                        </span>
                    </td>
                    <td class="text-end px-4">
                        <button class="btn btn-sm btn-light text-primary shadow-sm me-2 rounded-circle" data-bs-toggle="modal" data-bs-target="#categoryModal" data-id="@x.CategoryId" data-name="@x.CategoryName" data-description="@x.CategoryDescription" data-active="@(x.IsActive==true?"true":"false")" onclick="openCategory(this)" title="Edit">
                            <i class="bi bi-pencil-fill"></i>
                        </button>
                        <form class="d-inline" method="post" asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete this category?')">
                            <input type="hidden" name="id" value="@x.CategoryId"/>
                            <button class="btn btn-sm btn-light text-danger shadow-sm rounded-circle" title="Delete">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form class="modal-content" method="post" asp-action="Save">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="categoryModalTitle">Create category</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input id="categoryId" type="hidden" name="CategoryId"/>
                <div class="form-floating mb-3">
                    <input id="categoryName" class="form-control" name="CategoryName" placeholder="Name" required/>
                    <label for="categoryName">Category Name</label>
                </div>
                <div class="form-floating mb-3">
                    <textarea id="categoryDescription" class="form-control" name="CategoryDescription" placeholder="Description" style="height: 100px"></textarea>
                    <label for="categoryDescription">Description</label>
                </div>
                <div class="form-check form-switch mt-2">
                    <input class="form-check-input shadow-none" id="categoryActive" type="checkbox" name="IsActive" value="true"/>
                    <label class="form-check-label fw-medium ms-2" for="categoryActive">Set as Active</label>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4 px-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="bi bi-save me-1"></i> Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openCategory(button){
    const d=button?button.dataset:{};
    document.getElementById('categoryId').value=d.id||'0';
    document.getElementById('categoryName').value=d.name||'';
    document.getElementById('categoryDescription').value=d.description||'';
    document.getElementById('categoryActive').checked=d.active!=='false';
    document.getElementById('categoryModalTitle').innerHTML=d.id?'<i class="bi bi-pencil-square text-primary me-2"></i>Edit Category':'<i class="bi bi-plus-circle text-primary me-2"></i>Create Category';
}
</script>
}
